# Back-office — protégé par magic link (auth gérée en PHP) + non indexé.
DirectoryIndex index.php index.html

<IfModule mod_headers.c>
  Header always set X-Robots-Tag "noindex, nofollow"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  # L'admin n'est JAMAIS mis en cache (annule l'Expires hérité du docroot).
  Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  # CSP propre à l'admin : on ANNULE un éventuel CSP hérité du site (ex. panda avec
  # script-src 'self' qui bloquerait les scripts inline de l'éditeur) et on pose le nôtre,
  # qui autorise les scripts/styles inline du back-office tout en restant verrouillé sur 'self'.
  Header always unset Content-Security-Policy
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; frame-src 'self'; form-action 'self'; base-uri 'self'; frame-ancestors 'self'; object-src 'none'"
</IfModule>
<IfModule mod_expires.c>
  ExpiresActive Off
</IfModule>

# Empêche l'accès direct à un éventuel fichier non-php déposé ici par erreur.
<FilesMatch "\.(json|bak|log|txt)$">
  Require all denied
</FilesMatch>
